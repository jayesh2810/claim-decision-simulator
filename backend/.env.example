# Copy to `backend/.env` (optional). Pydantic loads from backend/.env when running uvicorn.
# Do not commit real API keys.

# Set true only for local demos: exposes GET /sample-claims with bundled JSON fixtures.
DEBUG=false

# Maximum upload size in bytes (default ~15 MB if omitted via code default).
# MAX_UPLOAD_BYTES=15728640

# Groq — create a key at https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# Optional: cap OCR text sent to the model (characters).
# DOCUMENT_TEXT_MAX_CHARS=48000

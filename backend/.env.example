# Copy to `backend/.env` (optional). Pydantic loads from backend/.env when running uvicorn.
# Do not commit real API keys.

# Set true only for local demos: exposes GET /sample-claims with bundled JSON fixtures.
DEBUG=false

# Maximum upload size in bytes (default ~15 MB if omitted via code default).
# MAX_UPLOAD_BYTES=15728640

# Groq — create a key at https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# Free / on-demand tier: Groq may return HTTP 413 when input+max_tokens exceeds token limits (not just JSON byte size).
# GROQ_COMPACT_SYSTEM_PROMPT=true
# GROQ_MAX_DOCUMENT_CHARS=12000
# GROQ_MAX_TOKENS=4096

# Optional: overall cap on extracted text (characters) before Groq-specific caps.
# DOCUMENT_TEXT_MAX_CHARS=32000

# Optional: max serialized JSON body (bytes), secondary tuning.
# GROQ_MAX_REQUEST_BODY_BYTES=28000
